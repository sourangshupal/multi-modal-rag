        <!-- ALB note in Public Subnet B -->
        <mxCell id="alb-b-note" value="ALB node in us-east-1b&#xa;&#xa;The ALB (doc-parser-alb) automatically&#xa;provisions a node in this subnet too.&#xa;&#xa;AWS REQUIRES at least 2 subnets&#xa;in different AZs to create an ALB.&#xa;&#xa;If us-east-1a becomes unavailable,&#xa;all traffic routes via this subnet." style="rounded=1;dashed=1;html=1;fillColor=light-dark(#EBE0FF,#2D1F5E);strokeColor=#8C4FFF;fontFamily=Helvetica;fontSize=11;fontColor=light-dark(#4A3080,#C0A0FF);align=center;verticalAlign=middle;" vertex="1" parent="1">
