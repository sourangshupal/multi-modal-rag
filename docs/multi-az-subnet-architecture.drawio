        <mxCell id="efs-shared-note" value="EFS is accessible here too&#xa;(multi-AZ, no duplication needed)" style="rounded=1;html=1;fillColor=light-dark(#E7F7E5,#1A3D18);strokeColor=#3F8624;fontFamily=Helvetica;fontSize=11;fontColor=light-dark(#1A4A10,#80D060);align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="878" y="870" width="380" height="60" as="geometry"/>
