        <!-- ECS standby note in Private Subnet B -->
        <mxCell id="ecs-b-note" value="ECS Fargate Standby — us-east-1b&#xa;&#xa;desiredCount=1: only 1 task runs at a time.&#xa;The task currently runs in us-east-1a.&#xa;&#xa;This private subnet is registered with&#xa;the ECS service so it can restart the task&#xa;here if us-east-1a becomes unhealthy.&#xa;&#xa;Scale-out (desiredCount &gt; 1) would&#xa;place additional tasks in this subnet,&#xa;distributing load across both AZs." style="rounded=1;dashed=1;html=1;fillColor=light-dark(#E8F4FB,#0D1E30);strokeColor=#147EBA;fontFamily=Helvetica;fontSize=11;fontColor=light-dark(#0A4A6A,#80C8F0);align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="878" y="548" width="450" height="260" as="geometry"/>
        </mxCell>

