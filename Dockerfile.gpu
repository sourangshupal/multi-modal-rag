# GPU image — use with docker-compose.gpu.yml on NVIDIA hardware (Lightning AI, etc.)
# Base image includes CUDA 12.1 runtime + cuDNN for PyTorch GPU acceleration.
# PP-DocLayoutV3 (layout detection) runs on GPU inside this container.
# GLM-OCR runs in the separate Ollama container, also GPU-accelerated.
FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

WORKDIR /app

# Avoid interactive prompts during apt installs
ENV DEBIAN_FRONTEND=noninteractive

# Python 3.12 is not in Ubuntu 22.04 default repos — add deadsnakes PPA first
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl software-properties-common && \
    add-apt-repository ppa:deadsnakes/ppa && \
    apt-get update && apt-get install -y --no-install-recommends \
    python3.12 python3.12-dev \
    libgl1 libglib2.0-0 && \
    rm -rf /var/lib/apt/lists/*

# Bootstrap pip for Python 3.12 (deadsnakes doesn't ship pip directly)
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3.12

# Make python3.12 the default python
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1

RUN pip install uv --no-cache-dir

# Install CUDA-enabled PyTorch FIRST so glmocr[layout] uses the GPU wheel.
# cu121 matches the CUDA 12.1 base image above.
RUN uv pip install --system --no-cache \
    torch torchvision \
    --extra-index-url https://download.pytorch.org/whl/cu121

# Install remaining deps (layer cache)
COPY pyproject.toml .
RUN uv pip install --system --no-cache -e ".[layout]"

COPY src/ src/
COPY scripts/ scripts/
COPY config.yaml .
COPY ollama/config.yaml ollama/config.yaml

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Tell PyTorch/HuggingFace to use GPU 0 by default
ENV CUDA_VISIBLE_DEVICES=0

EXPOSE 8000
CMD ["python", "scripts/serve.py"]
