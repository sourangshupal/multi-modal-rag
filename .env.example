PARSER_BACKEND=cloud          # "cloud" (Z.AI MaaS) | "ollama" (local Ollama)
Z_AI_API_KEY=your-z-ai-api-key-here
LOG_LEVEL=INFO
OUTPUT_DIR=./output

# OpenAI / RunPod (OPENAI_API_KEY holds RunPod API key; OPENAI_BASE_URL points to RunPod endpoint)
OPENAI_API_KEY=your-runpod-api-key-here
OPENAI_BASE_URL=https://api.runpod.ai/v2/<endpoint-id>/openai/v1
OPENAI_LLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# Embedding provider
EMBEDDING_PROVIDER=qwen          # "openai" | "gemini" | "qwen"
QWEN_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-2B
EMBEDDING_DIMENSIONS=2048
# ⚠ Changing EMBEDDING_DIMENSIONS after collection creation requires --overwrite

# Gemini (only needed if EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=                  # AIzaSy...

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents

# Reranker
RERANKER_BACKEND=qwen         # "jina" | "openai" | "bge" | "qwen"
RERANKER_TOP_N=5
JINA_API_KEY=                  # only needed if RERANKER_BACKEND=jina

# Feature flags
# When true, enrich_chunks() runs during ingestion:
#   - image chunks: region is cropped and stored as image_base64 for direct visual embedding (no LLM call)
#   - table/formula/algorithm chunks: a text description is generated via OPENAI_LLM_MODEL
IMAGE_CAPTION_ENABLED=true

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Logging
LOG_JSON=false   # true = JSON lines for log aggregators
